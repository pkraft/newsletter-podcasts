{
  "name": "newsletter-podcasts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Turns newsletter issues (text + TTS audio + transcript) into published podcast episodes on GitHub Pages.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "ingest": "tsx src/ingest.ts",
    "build": "tsx src/build.ts",
    "build:admin": "vite build",
    "dev:admin": "vite",
    "typecheck:admin": "tsc -p admin",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "marked": "^18.0.6",
    "node-id3": "^0.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sanitize-html": "^2.17.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.1.5"
  }
}
