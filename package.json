{
  "name": "newsletter-podcasts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Turns newsletter issues (text + TTS audio + transcript) into published podcast episodes on GitHub Pages.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "ingest": "tsx src/ingest.ts",
    "build": "tsx src/build.ts",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "node-id3": "^0.2.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
